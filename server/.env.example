# Copy to .env and fill in. Never commit .env.
NODE_ENV=development
PORT=8080
HOST=0.0.0.0

# MongoDB connection string. For local: mongodb://localhost:27017/choresapp
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>

# JWT signing secret. Use 32+ random chars (e.g. `openssl rand -base64 48`).
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars_long_xxxxxxx

# AES key-encryption secret (used to encrypt household OpenAI keys at rest).
# MUST be different from JWT_SECRET. 32+ chars. Rotating this invalidates all stored keys.
KEY_ENCRYPTION_SECRET=replace_with_a_separate_long_random_string_at_least_32_chars_x

LOG_LEVEL=info
